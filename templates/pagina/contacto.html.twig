{% extends 'layouts/base.html.twig' %}

{% block title %}
    Contacto
{% endblock %}

{% block body %}

<h2>
    Contacto
</h2>

<form id="formulario-contacto">

    <label>
        Nombre
    </label>

    <input type="text"
           id="nombre"
           placeholder="Ingrese su nombre">

    <small id="error-nombre"
           class="error-texto"></small>

    <label>
        Correo
    </label>

    <input type="email"
           id="correo"
           placeholder="Ingrese su correo">

    <small id="error-correo"
           class="error-texto"></small>

    <label>
        Mensaje
    </label>

    <textarea rows="5"
              id="mensaje"></textarea>

    <small id="error-mensaje"
           class="error-texto"></small>

    <button type="submit">

        Enviar

    </button>

</form>

<div id="mensaje-exito"
     class="alerta-exito"
     style="display:none;">

    Mensaje enviado correctamente.

</div>

<script>

document.getElementById('formulario-contacto')

.addEventListener('submit', function(e){

    e.preventDefault();

    let nombre = document.getElementById('nombre').value.trim();

    let correo = document.getElementById('correo').value.trim();

    let mensaje = document.getElementById('mensaje').value.trim();

    let valido = true;

    document.getElementById('error-nombre').innerText = '';

    document.getElementById('error-correo').innerText = '';

    document.getElementById('error-mensaje').innerText = '';

    document.getElementById('mensaje-exito').style.display = 'none';

    if(nombre.length < 3){

        document.getElementById('error-nombre').innerText =
        'El nombre debe tener al menos 3 caracteres.';

        valido = false;

    }

    if(!correo.includes('@')){

        document.getElementById('error-correo').innerText =
        'Ingrese un correo válido.';

        valido = false;

    }

    if(mensaje.length < 10){

        document.getElementById('error-mensaje').innerText =
        'El mensaje debe tener mínimo 10 caracteres.';

        valido = false;

    }

    if(valido){

        document.getElementById('mensaje-exito').style.display =
        'block';

    }

});

</script>

{% endblock %}